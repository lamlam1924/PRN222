@model IEnumerable<TravelDataAccess.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
    var isAdmin = ViewBag.IsAdmin ?? false;
}

<h2>@(isAdmin ? "All Bookings" : "My Bookings")</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New</a>
    <a asp-action="Index" class="btn btn-secondary">All</a>
    <a asp-action="Index" asp-route-filter="pending" class="btn btn-warning">Pending Only</a>
</div>

@if (ViewBag.Filter == "pending")
{
    <div class="alert alert-info">Showing Pending bookings only</div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Date</th>
            <th>Status</th>
            @if (isAdmin)
            {
                <th>Customer</th>
            }
            <th>Trip</th>
            <th>Destination</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.BookingDate.ToString("dd/MM/yyyy")</td>
            <td>@item.Status</td>
            @if (isAdmin)
            {
                <td>@item.Customer.FullName (@item.Customer.Code)</td>
            }
            <td>@item.Trip.Code</td>
            <td>@item.Trip.Destination</td>
            <td>@item.Trip.Price.ToString("N0") VND</td>
            <td>
                @if (item.Status == "Pending")
                {
                    <form asp-action="UpdateStatus" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.BookingID" />
                        <input type="hidden" name="status" value="Confirmed" />
                        <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                    </form>
                    <form asp-action="UpdateStatus" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.BookingID" />
                        <input type="hidden" name="status" value="Cancelled" />
                        <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                    </form>
                }
                <a asp-action="Details" asp-route-id="@item.BookingID" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.BookingID" class="btn btn-sm btn-warning">Edit</a>
            </td>
        </tr>
}
    </tbody>
</table>

@model IEnumerable<SU26_PRN222_Healthcare.CareBusiness.Entities.Appointment>
@{
    ViewData["Title"] = "All Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📋 All Appointments</h2>
        <p class="text-muted mb-0">Admin view – filter and manage all patient appointments</p>
    </div>
    <a asp-action="DoctorSlots" class="btn btn-outline-primary">📊 Doctor Slots</a>
</div>

<!-- Filter Form -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="AllAppointments">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Appointment Date</label>
                    <input type="date" name="date" class="form-control" value="@ViewBag.FilterDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Doctor</label>
                    <select name="doctorId" class="form-select">
                        <option value="">— All Doctors —</option>
                        @{
                            var filterDoctorId = ViewBag.FilterDoctorId?.ToString();
                            foreach (var doc in (List<SU26_PRN222_Healthcare.CareBusiness.Entities.Doctor>)ViewBag.Doctors)
                            {
                                if (filterDoctorId == doc.ID.ToString())
                                { <option value="@doc.ID" selected>@doc.DoctorName</option> }
                                else
                                { <option value="@doc.ID">@doc.DoctorName</option> }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Patient</label>
                    <select name="patientId" class="form-select">
                        <option value="">— All Patients —</option>
                        @{
                            var filterPatientId = ViewBag.FilterPatientId?.ToString();
                            foreach (var p in (List<SU26_PRN222_Healthcare.CareBusiness.Entities.User>)ViewBag.Patients)
                            {
                                if (filterPatientId == p.ID.ToString())
                                { <option value="@p.ID" selected>@p.FullName</option> }
                                else
                                { <option value="@p.ID">@p.FullName</option> }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">🔍 Filter</button>
                    <a asp-action="AllAppointments" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Results: <strong>@Model.Count()</strong> appointment(s)</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:2.5rem">📋</div>
                <p class="mt-2">No appointments match the filter criteria.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>Booked On</th>
                            <th>Appointment Date</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model)
                        {
                            <tr class="@(appt.IsCancelled ? "table-secondary opacity-75" : "")">
                                <td class="text-muted">@appt.ID</td>
                                <td class="fw-semibold">@(appt.Patient?.FullName ?? "–")</td>
                                <td>@(appt.Doctor?.DoctorName ?? "–")</td>
                                <td><span class="badge bg-primary rounded-pill">@(appt.Doctor?.Specialty ?? "–")</span></td>
                                <td class="text-muted small">@appt.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@appt.AppointmentDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (appt.IsCancelled)
                                    {
                                        <span class="badge bg-danger">❌ Cancelled</span>
                                    }
                                    else if (appt.AppointmentDate.Date >= DateTime.Today)
                                    {
                                        <span class="badge bg-success">✅ Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">📜 Past</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!appt.IsCancelled)
                                    {
                                        <form asp-action="CancelAdmin" asp-route-id="@appt.ID" method="post"
                                              onsubmit="return confirm('Cancel appointment #@appt.ID?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">🚫 Cancel</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">–</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

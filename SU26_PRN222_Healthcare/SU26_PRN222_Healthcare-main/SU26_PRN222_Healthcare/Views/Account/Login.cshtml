@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg">
            <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #1a73e8, #0d47a1);">
                <h3 class="mb-0">🏥 CareClinic</h3>
                <p class="mb-0 mt-1 opacity-75 small">Healthcare Appointment System</p>
            </div>
            <div class="card-body p-4">
                <h5 class="mb-4 text-center text-muted">Sign in to your account</h5>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">❌ @ViewBag.Error</div>
                }

                <form method="post" asp-controller="Account" asp-action="Login">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email Address</label>
                        <input type="email" name="email" class="form-control form-control-lg"
                               placeholder="Enter your email" required autofocus />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Password</label>
                        <input type="password" name="password" class="form-control form-control-lg"
                               placeholder="Enter your password" required />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Sign In</button>
                </form>

                <hr class="my-3">
                <p class="text-center mb-0">
                    Don't have an account?
                    <a asp-controller="Account" asp-action="Register" class="text-primary fw-semibold">Register here</a>
                </p>
            </div>
            <div class="card-footer text-muted text-center small py-3 bg-light">
                <strong>Demo accounts:</strong><br/>
                Admin: <code>admin@care.com</code> / <code>Admin@123</code><br/>
                Patient: <code>patient@care.com</code> / <code>Patient@123</code>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<SU26_PRN222_Healthcare.CareBusiness.Entities.Doctor>
@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="mb-4">
    <h2>🔍 Find a Doctor</h2>
    <p class="text-muted">Search by name, specialty, or license number</p>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Search">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Doctor Name</label>
                    <input type="text" name="name" class="form-control" placeholder="e.g. Nguyen Van A"
                           value="@ViewBag.SearchName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Specialty</label>
                    <input type="text" name="specialty" class="form-control" placeholder="e.g. Cardiology"
                           value="@ViewBag.SearchSpecialty" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">License Number</label>
                    <input type="text" name="licenseNumber" class="form-control" placeholder="e.g. LIC-001"
                           value="@ViewBag.SearchLicense" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">🔍 Search</button>
                <a asp-action="Search" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.Searched == true)
{
    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            <strong>No doctors available for the selected criteria.</strong>
            <p class="mb-0 mt-1 small">Try adjusting your search filters.</p>
        </div>
    }
    else
    {
        <p class="text-muted mb-3">Found <strong>@Model.Count()</strong> doctor(s)</p>
        <div class="row g-3">
            @foreach (var doc in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(doc.Active ? "" : "opacity-75")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0 fw-semibold">@doc.DoctorName</h5>
                                @if (doc.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>
                            <p class="mb-1"><span class="badge bg-primary">@doc.Specialty</span></p>
                            <p class="text-muted mb-1 small">License: <code>@doc.LicenseNumber</code></p>
                            <p class="text-muted mb-3 small">Max @doc.MaxPatients patients/day</p>
                            @if (doc.Active)
                            {
                                <a asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@doc.ID"
                                   class="btn btn-primary btn-sm w-100">📅 Book Appointment</a>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm w-100" disabled>Not Available</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🏥</div>
        <p class="mt-2">Enter search criteria above to find available doctors.</p>
    </div>
}

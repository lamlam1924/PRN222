@model SU26_PRN222_Healthcare.CareBusiness.Entities.Doctor
@{
    ViewData["Title"] = "Add New Doctor";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">← Back</a>
            <h2 class="mb-0">➕ Add New Doctor</h2>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form method="post" asp-action="Create">
                    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="DoctorName" class="form-label fw-semibold">Doctor Name <span class="text-danger">*</span></label>
                        <input asp-for="DoctorName" class="form-control" placeholder="e.g. Dr. Nguyen Van A" />
                        <span asp-validation-for="DoctorName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Specialty" class="form-label fw-semibold">Specialty <span class="text-danger">*</span></label>
                        <input asp-for="Specialty" class="form-control" placeholder="e.g. Cardiology" />
                        <span asp-validation-for="Specialty" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LicenseNumber" class="form-label fw-semibold">License Number <span class="text-danger">*</span></label>
                        <input asp-for="LicenseNumber" class="form-control" placeholder="e.g. LIC-001" />
                        <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaxPatients" class="form-label fw-semibold">Max Patients Per Day</label>
                        <input asp-for="MaxPatients" type="number" min="0" class="form-control" value="10" />
                        <span asp-validation-for="MaxPatients" class="text-danger small"></span>
                        <div class="form-text">Maximum number of appointments allowed per day.</div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="Active" class="form-check-input" type="checkbox" checked />
                            <label asp-for="Active" class="form-check-label fw-semibold">Active (available for booking)</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">✅ Add Doctor</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<SU26_PRN222_Healthcare.CareBusiness.Entities.Doctor>
@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">👨‍⚕️ Manage Doctors</h2>
        <p class="text-muted mb-0">Admin panel – view and manage all doctors</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        ➕ Add New Doctor
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:3rem">🏥</div>
                <p class="mt-2">No doctors registered yet. Click <strong>Add New Doctor</strong> to get started.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Doctor Name</th>
                            <th>Specialty</th>
                            <th>License Number</th>
                            <th>Max Patients/Day</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            <tr>
                                <td class="text-muted">@doc.ID</td>
                                <td class="fw-semibold">@doc.DoctorName</td>
                                <td><span class="badge bg-primary rounded-pill">@doc.Specialty</span></td>
                                <td><code>@doc.LicenseNumber</code></td>
                                <td>@doc.MaxPatients</td>
                                <td>
                                    @if (doc.Active)
                                    {
                                        <span class="badge bg-success">✅ Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">⛔ Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@doc.ID" class="btn btn-sm btn-outline-primary me-1">✏️ Edit</a>
                                    <form asp-action="Delete" asp-route-id="@doc.ID" method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete Dr. @doc.DoctorName? This cannot be undone.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
